# ─────────────────────────────────────────────────────────────────────────────
# Even Keel Learning — environment variable reference
#
# Copy this file to `.env.local` and fill in the values for your environment.
# Never commit `.env.local` or any file that contains real secrets.
#
# ⚠️  IMPORTANT: Variables prefixed with NEXT_PUBLIC_ are bundled into the
#    client-side JavaScript bundle and are visible to anyone who visits the
#    site. They are NOT secret. Do not put real passwords, API keys or private
#    data in NEXT_PUBLIC_ variables.
# ─────────────────────────────────────────────────────────────────────────────


# ─── Role guard passphrases (CLIENT-VISIBLE — not secret) ────────────────────
#
# These guard the teacher, compliance and author surfaces in the demo. Because
# they are NEXT_PUBLIC_ they are embedded in the browser bundle. They are
# suitable only for demo-mode access control. Replace with proper server-side
# authentication (WebAuthn, session tokens) before production launch.
#
NEXT_PUBLIC_TEACHER_PASSPHRASE=mentor-alpha-42
NEXT_PUBLIC_COMPLIANCE_PASSPHRASE=officer-alpha-42
NEXT_PUBLIC_AUTHOR_PASSPHRASE=reviewer-alpha-42


# ─── Zero-Knowledge aggregator salt (SERVER-SIDE — keep secret) ──────────────
#
# Used by lib/zero-knowledge/aggregator.ts to pseudonymise student IDs before
# aggregation. The current implementation is a 32-bit djb2 hash and is NOT
# cryptographically strong anonymisation (see HONESTY.md §4.4). The salt
# should still be rotated periodically and kept server-side only (no
# NEXT_PUBLIC_ prefix).
#
# Generate a random value, e.g.: openssl rand -hex 32
#
ZK_SALT=change-me-before-production


# ─── Content authoring script (scripts/author-draft.mjs) ─────────────────────
#
# These are only needed when running `node scripts/author-draft.mjs` locally.
# They are never loaded by the Next.js app at runtime.
#
# LLM_PROVIDER selects the backend: "mock" (default), "anthropic", or "openai".
LLM_PROVIDER=mock

# Model override — leave blank to use the provider's default.
# Anthropic example: claude-sonnet-4-5
# OpenAI example:    gpt-4o
LLM_MODEL=

# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Required when LLM_PROVIDER=openai
OPENAI_API_KEY=


# ─── Content manifest build (scripts/build-content-manifest.mjs) ─────────────
#
# Optional human-readable name embedded in generated manifests for audit trails.
CONTENT_REVIEWER_NAME=Local Dev Reviewer
